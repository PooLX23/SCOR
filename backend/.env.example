DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/db
DB_SCHEMA=scor
DB_REBUILD_ON_START=false
AUTH_MODE=entra
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=api://
RECEPTION_GROUP_ID=  # grupa recenzentów/weryfikatorów
WINDYKACJA_GROUP_ID=  # grupa windykacji
APP_PUBLIC_URL=http://localhost:5173

# Graph app credentials (do uploadu na SharePoint)
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ROOT_FOLDER=scor-wnioski

# Słownik grup samochodów (MSSQL)
MSSQL_CAR_GROUPS_URL=
MSSQL_SYMFONIA_URL=
# Przykład SQL login (zalecane na Linux/systemd):
# MSSQL_CAR_GROUPS_URL=mssql+pyodbc://USER:HASLO@192.168.10.11/Eurorent?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
